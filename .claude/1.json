{
  "permissions": {
    "allow": [
      "WebFetch(domain:pypi.org)"
    ]
  },
  "environment": {
    "MLFLOW_CLAUDE_TRACING_ENABLED": "true",
    "MLFLOW_TRACKING_URI": "databricks://mlops-book",
    "MLFLOW_EXPERIMENT_NAME": "/Workspace/Shared/brickkit",
    "DATABRICKS_CONFIG_PROFILE": "mlops-book"
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run pre-commit run --all-files"
          },
          {
            "type": "command",
            "command": "uv run python -c \"from mlflow.claude_code.hooks import stop_hook_handler; stop_hook_handler()\""
          }
        ]
      }
    ]
  }
}
